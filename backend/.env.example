# ==============================================================================
# APEX Backend — Environment Configuration Template
# ==============================================================================
# Copy this file to .env and fill in the required values.
# The .env file is gitignored — NEVER commit secrets to version control.
# ==============================================================================

# ── Application ────────────────────────────────────────────────────────────────
ENVIRONMENT=development          # development | staging | production
LOG_LEVEL=INFO                   # DEBUG | INFO | WARNING | ERROR

# ── AI Provider ────────────────────────────────────────────────────────────────
# Choose which AI provider powers decisions, embeddings, and runbook generation.
# mock   -> No API keys needed. All AI outputs are deterministic. Good for CI/dev.
# gemini -> Google Gemini API. Requires GEMINI_API_KEY.
# nim    -> NVIDIA NIM API. Requires NIM_API_KEY.
#
# DEFAULT_LLM_PROVIDER is the preferred setting name. AI_PROVIDER is still supported
# as a legacy alias for older environments and tests.

DEFAULT_LLM_PROVIDER=gemini

# Google Gemini (https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
GEMINI_EMBEDDING_MODEL=text-embedding-004

# NVIDIA NIM (https://build.nvidia.com/explore/discover)
NIM_API_KEY=
NIM_BASE_URL=https://integrate.api.nvidia.com/v1
NIM_RETRIEVAL_BASE_URL=https://ai.api.nvidia.com/v1/retrieval/nvidia
NIM_MODEL=meta/llama-3.1-70b-instruct
NIM_OCR_MODEL=nemotron-ocr-v2
NIM_EMBED_MODEL=nvidia/embed-qa-4

# ── Vector Database ────────────────────────────────────────────────────────────
# Set QDRANT_URL for Qdrant Cloud or a remote instance.
# Use QDRANT_HOST/QDRANT_PORT for a local deployment.
# Leave both empty to use in-memory Qdrant (data lost on restart).

QDRANT_URL=
QDRANT_API_KEY=
QDRANT_HOST=                     # e.g. qdrant (Docker service) or localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=apex_documents
EMBEDDING_DIMENSION=768

# ── Security / CORS ────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# In production, replace with your actual frontend URL.

CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# ── Feature Flags ──────────────────────────────────────────────────────────────
ENABLE_TELEMETRY=false
ENABLE_OCR=true
DEFAULT_OCR_PROVIDER=mock
ENABLE_MOCK_OCR=false            # Explicit opt-in for demo-only OCR fallback
MAX_UPLOAD_SIZE_MB=50
